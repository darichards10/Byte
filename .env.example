# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Discord bot token — from Discord Developer Portal > Bot > Token
DISCORD_TOKEN=your_discord_bot_token_here

# Anthropic API key — from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DynamoDB table name (matches infra/02-dynamodb.yaml)
DYNAMODB_TABLE=ByteBot

# AWS region for all services
AWS_REGION=us-east-1

# Name of the Discord channel where Byte responds to free-form messages
# Create a channel named exactly this in your Discord server
BOT_CHAT_CHANNEL=byte-chat

# Set to "local" for docker-compose dev, "production" for ECS
ENVIRONMENT=local

# Used by local DynamoDB docker-compose setup only
DYNAMODB_ENDPOINT=http://localhost:8000

# AWS credentials — NOT needed in .env for local dev.
# docker-compose.yml injects fake credentials (AWS_ACCESS_KEY_ID=local, etc.)
# that satisfy boto3's signing requirement against DynamoDB Local.
# For production, real credentials come from the ECS Task IAM Role automatically.
